{
  "name": "hyper-html-api",
  "description": "self-describing data layer for HTML files — extract, apply, CMS, upgrade",
  "keywords": [
    "HTML",
    "DOM",
    "data",
    "extract",
    "apply",
    "CMS"
  ],
  "version": "0.1.0",
  "homepage": "https://github.com/panphora/hyper-html-api",
  "bugs": {
    "url": "https://github.com/panphora/hyper-html-api/issues"
  },
  "license": "0BSD",
  "files": [
    "LICENSE",
    "README.md",
    "src/**/*.js",
    "dist/*.js"
  ],
  "main": "src/hyper-html-api.js",
  "module": "src/hyper-html-api.js",
  "type": "module",
  "exports": {
    ".": "./src/hyper-html-api.js",
    "./engine": "./src/engine/index.js",
    "./cheerio": "./src/adapters/cheerio.js",
    "./dom": "./src/adapters/dom.js"
  },
  "scripts": {
    "build": "npx esbuild src/hyper-html-api.js --bundle --minify --format=iife --global-name=HyperHtmlApi --outfile=dist/hyper-html-api.min.js",
    "copy-to-hyperclayjs": "npm run build && node scripts/copy-to-hyperclayjs.js",
    "demo": "http-server . -p 5693 -c-1 -o /demo/",
    "test": "web-test-runner",
    "test:debug": "web-test-runner --manual --open",
    "test:chrome": "web-test-runner --playwright --browsers chromium",
    "test:firefox": "web-test-runner --concurrency 1 --playwright --browsers firefox",
    "test:webkit": "web-test-runner --playwright --browsers webkit",
    "test:all": "web-test-runner --concurrency 1 --playwright --browsers chromium firefox webkit",
    "test:node": "node --test 'test-node/**/*.test.js'",
    "test:ci": "npm run test:node && npm run test:all -- --fail-only && node test/lib/ensure-full-coverage.js",
    "test:coverage": "npm run test:chrome && node test/lib/ensure-full-coverage.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panphora/hyper-html-api.git"
  },
  "devDependencies": {
    "@web/test-runner": "^0.20.0",
    "@web/test-runner-playwright": "^0.11.0",
    "chai": "^4.3.6",
    "chai-dom": "^1.11.0",
    "cheerio": "^1.0.0-rc.12",
    "esbuild": "^0.24.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.2",
    "lcov-parse": "^1.0.0",
    "mocha": "^11.0.1",
    "prettier": "^3.4.2",
    "sinon": "^9.2.4"
  }
}
